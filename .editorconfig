root = true

[*]
charset = utf-8
end_of_line = crlf
insert_final_newline = true
trim_trailing_whitespace = true

[*.cs]
indent_style = space
indent_size = 4

[*.{json,asmdef,asmref}]
indent_style = space
indent_size = 4

[*.{asset,unity,prefab,meta}]
indent_style = space
indent_size = 2
trim_trailing_whitespace = false
